#!/bin/bash

LOG_FILE="/var/log/xxx_menu.log"

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
WHITE='\033[1;37m'
GRAY='\033[1;30m'
NC='\033[0m'

log() {
    echo -e "$(date '+%F %T') ${YELLOW}$1${NC}" | tee -a "$LOG_FILE"
}

pause() {
    read -p "按回车继续..."
}

# ================= 狂暴血腥熊猫头 =================
show_panda() {
    clear
    # 注意：这里使用去除了单引号的 EOF，这样才能解析颜色变量
    cat << EOF
${GRAY}       ▄▄▄▄▄▄▄                  ▄▄▄▄▄▄▄
${GRAY}     ▄█████████▄              ▄█████████▄
${GRAY}    █████████████▄${WHITE}▀▀▀▀▀▀▀▀▀▀${GRAY}▄█████████████
${GRAY}    ▀███████████▀${WHITE}            ▀███████████▀
${GRAY}      ▀▀█████▀▀${WHITE}    ▄▄▄  ▄▄▄    ▀▀█████▀▀
${WHITE}        ▄██▀${RED} ▄▄▄${WHITE}   ▀██▄▄██▀   ${RED}▄▄▄${WHITE} ▀██▄
${WHITE}       ███ ${RED}▄█████▄${WHITE}  ▀████▀  ${RED}▄█████▄${WHITE} ███
${WHITE}       ██▄ ${RED}▀██████${WHITE}          ${RED}██████▀${WHITE} ▄██
${WHITE}       ▀██▄  ${RED}▀▀▀▀${WHITE}   ▄▄▄▄▄▄   ${RED}▀▀▀▀${WHITE}  ▄██▀
${RED} ▄▄${WHITE}      ██▄      ▄████████▄      ▄██      ${RED}▄▄
${RED}▀███▄${WHITE}     ▀█████████${RED}▀▀▀▀▀▀${WHITE}█████████▀     ${RED}▄███▀
${CYAN} ▀████▄${WHITE}      ▀█████${RED}▄██████▄${WHITE}█████▀      ${CYAN}▄████▀
${CYAN}  ▀██████▄▄${WHITE}     ▀██${RED}▀██████▀${WHITE}██▀     ${CYAN}▄▄██████▀
${CYAN} ▄▄▄█████████▄▄${WHITE}    ▀▀${RED}████${WHITE}▀▀    ${CYAN}▄▄█████████▄▄
${CYAN} ████████████████▄▄${RED}  ▀▀  ${CYAN}▄▄████████████████${NC}
EOF
    echo -e "${RED}      >>> WARNING: BLOODTHIRSTY OVERRIDE <<<${NC}"
    sleep 2
}

# ================= 主菜单 =================
main_menu() {
    while true; do
        clear
        echo -e "${CYAN}===== 主菜单 =====${NC}"
        echo -e "${GREEN}1 SMB${NC}"
        echo -e "${YELLOW}2 Docker${NC}"
        echo -e "${BLUE}3 SSH${NC}"
        echo -e "${MAGENTA}4 GO${NC}"
        echo -e "${CYAN}5 服务项${NC}"
        echo -e "${RED}6 取消${NC}"
        read -p "请选择: " choice

        case $choice in
            1) smb_menu ;;
            2) docker_menu ;;
            3) ssh_menu ;;
            4) go_menu ;;
            5) service_menu ;;
            6) exit 0 ;;
        esac
    done
}

# ================= SMB (绿色) =================
smb_menu() {
    while true; do
        clear
        echo -e "${GREEN}===== SMB 菜单 =====${NC}"
        echo -e "${GREEN}1 SMB安装并开机启动${NC}"
        echo -e "${GREEN}2 SMB配置(共享 /X 全权限)${NC}"
        echo -e "${GREEN}3 SMB服务状态查询${NC}"
        echo -e "${GREEN}4 重启 SMB${NC}"
        echo -e "${GREEN}5 删除配置并关闭启动${NC}"
        echo -e "${RED}6 返回${NC}"
        read -p "选择: " c

        case $c in
            1)
                apt update
                apt install -y samba
                systemctl enable smbd
                log "SMB 已安装并设置开机启动"
                ;;
            2)
                mkdir -p /X
                cat > /etc/samba/smb.conf <<'EOF'
[global]
workgroup = WORKGROUP
security = user
map to guest = Bad User

[X]
path = /X
browseable = yes
read only = no
guest ok = yes
create mask = 0777
directory mask = 0777
EOF
                chmod -R 777 /X
                systemctl restart smbd
                log "SMB 配置已写入，并已设置 /X 权限为 777"
                ;;
            3)
                systemctl status smbd
                log "SMB 服务状态查询"
                ;;
            4)
                systemctl restart smbd
                log "SMB 服务已重启"
                ;;
            5)
                rm -f /etc/samba/smb.conf
                systemctl disable smbd
                log "SMB 配置已删除并关闭启动"
                ;;
            6) break ;;
        esac
        pause
    done
}

# ================= Docker (黄色) =================
docker_menu() {
    while true; do
        clear
        echo -e "${YELLOW}===== Docker 菜单 =====${NC}"
        echo -e "${YELLOW}1 安装 Docker${NC}"
        echo -e "${YELLOW}2 重启 Docker${NC}"
        echo -e "${RED}3 返回${NC}"
        read -p "选择: " c

        case $c in
            1)
                curl -fsSL https://get.docker.com -o get-docker.sh
                sh get-docker.sh
                log "Docker 安装完成"
                ;;
            2)
                systemctl restart docker
                log "Docker 已重启"
                ;;
            3) break ;;
        esac
        pause
    done
}

# ================= SSH (蓝色) =================
ssh_menu() {
    while true; do
        clear
        echo -e "${BLUE}===== SSH 菜单 =====${NC}"
        echo -e "${BLUE}1 安装并启用 SSH${NC}"
        echo -e "${BLUE}2 强制写入配置${NC}"
        echo -e "${BLUE}3 查询状态${NC}"
        echo -e "${BLUE}4 重启 SSH${NC}"
        echo -e "${RED}5 返回${NC}"
        read -p "选择: " c

        case $c in
            1)
                apt install -y openssh-server
                systemctl enable ssh
                log "SSH 已安装并开机启动"
                ;;
            2)
                sed -i 's/^#\?PasswordAuthentication.*/PasswordAuthentication yes/' /etc/ssh/sshd_config
                sed -i 's/^#\?PermitRootLogin.*/PermitRootLogin yes/' /etc/ssh/sshd_config
                systemctl restart ssh
                log "SSH 配置已写入"
                ;;
            3)
                systemctl status ssh
                log "SSH 状态查询"
                ;;
            4)
                systemctl restart ssh
                log "SSH 已重启"
                ;;
            5) break ;;
        esac
        pause
    done
}

# ================= GO (紫色) =================
go_menu() {
    while true; do
        clear
        echo -e "${MAGENTA}===== GO 菜单 =====${NC}"
        echo -e "${MAGENTA}1 安装 GO${NC}"
        echo -e "${RED}2 返回${NC}"
        read -p "选择: " c

        case $c in
            1)
                apt update
                apt install -y golang
                log "GO 已安装"
                ;;
            2) break ;;
        esac
        pause
    done
}

# ================= 服务项 (青色) =================
service_menu() {
    while true; do
        clear
        echo -e "${CYAN}===== 服务菜单 =====${NC}"
        echo -e "${CYAN}1 创建xxx.service${NC}"
        echo -e "${CYAN}2 启动xxx服务${NC}"
        echo -e "${CYAN}3 查询状态${NC}"
        echo -e "${CYAN}4 创建胖墩墩超级备份系统${NC}"
        echo -e "${RED}5 返回${NC}"
        read -p "选择: " c

        case $c in
            1)
cat << 'EOF' > /etc/systemd/system/xxx.service
[Unit]
Description=Docker Cluster Management System
After=network.target

[Service]
WorkingDirectory=/X
ExecStart=/X/xxx
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
EOF
                systemctl daemon-reload
                systemctl enable xxx
                log "xxx.service 已写入，设置开机启动"
                ;;
            2)
                systemctl restart xxx
                log "xxx 已重启"
                ;;
            3)
                systemctl status xxx
                log "查询 xxx 状态"
                ;;
            4)
                mkdir -p /X

                # 自动检测并安装 Go
                if ! command -v go >/dev/null 2>&1; then
                    log "未检测到 Go 环境，正在自动安装..."
                    apt update
                    apt install -y golang
                fi

                cat > /X/xxx.go <<'EOF'
package main

import (
	"fmt"
	"github.com/gin-gonic/gin"
	"app/backup"
)

func main() {
	r := gin.Default()
	backup.RegisterBackupHandler(r, "/back_up", "/X")

	fmt.Println("http://localhost/back_up")

	r.Run(":80")
}
EOF
                log "xxx.go创建完成"

                # 必须在编译前先创建 backup 目录并下载 backup.go
                mkdir -p /X/backup
                log "/X/backup创建完成"
                chmod -R 777 /X/backup
                log "/X/backup给予777权限"
                wget -q -O /X/backup/backup.go "https://raw.githubusercontent.com/ZackOd/sh/refs/heads/main/backup.go"
                log "/X/backup/backup.go下载完成"

                # 进入 /X 目录执行编译
                cd /X || exit

                go mod init app
                go get github.com/gin-gonic/gin
                go mod tidy
                log "系统初始化完成"
                
                # 开始编译
                go build -o xxx xxx.go
                chmod +x xxx
                log "系统编译完成"
                
                # 返回原始目录
                cd - > /dev/null

                systemctl restart xxx
                log "超级备份系统已启动: http://$(hostname -I | awk '{print $1}')/back_up"
                ;;
            5) break ;;
        esac
        pause
    done
}

# 启动
show_panda
main_menu
