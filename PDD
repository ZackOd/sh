# ================= 主菜单 =================
main_menu() {
    while true; do
        print_header "${CYAN}===== 主菜单 =====${NC}"
        echo -e "${GREEN}1 SMB${NC}"
        echo -e "${YELLOW}2 Docker${NC}"
        echo -e "${BLUE}3 SSH${NC}"
        echo -e "${MAGENTA}4 GO${NC}"
        echo -e "${CYAN}5 服务项${NC}"
        echo -e "${RED}6 取消${NC}"
        read -p "请选择: " choice

        case $choice in
            1) smb_menu ;;
            2) docker_menu ;;
            3) ssh_menu ;;
            4) go_menu ;;
            5) service_menu ;;
            6) clear; exit 0 ;;
        esac
    done
}

# ================= SMB (绿色) =================
smb_menu() {
    while true; do
        print_header "${GREEN}===== SMB 菜单 =====${NC}"
        echo -e "${GREEN}1 SMB安装并开机启动${NC}"
        echo -e "${GREEN}2 SMB配置(共享 /X 全权限)${NC}"
        echo -e "${GREEN}3 自定义共享目录${NC}"
        echo -e "${GREEN}4 SMB服务状态查询${NC}"
        echo -e "${GREEN}5 重启 SMB${NC}"
        echo -e "${GREEN}6 删除配置并关闭启动${NC}"
        echo -e "${RED}7 取消/返回${NC}"
        read -p "选择: " c

        case $c in
            1)
                apt update
                apt install -y samba
                systemctl enable smbd
                log "SMB 已安装并设置开机启动"
                ;;

            2)
                mkdir -p /X
                cat > /etc/samba/smb.conf <<'EOF'
[global]
workgroup = WORKGROUP
security = user
map to guest = Bad User

[X]
path = /X
browseable = yes
read only = no
guest ok = yes
create mask = 0777
directory mask = 0777
EOF
                chmod -R 777 /X
                systemctl restart smbd
                log "SMB 配置已写入，并已设置 /X 权限为 777"
                ;;

            3)
                read -p "请输入绝对路径 (如 /data/share): " custom_path

                # 判空
                if [ -z "$custom_path" ]; then
                    log "路径不能为空"
                    continue
                fi

                # 必须是绝对路径
                if [[ "$custom_path" != /* ]]; then
                    log "必须输入绝对路径"
                    continue
                fi

                # 创建目录
                mkdir -p "$custom_path"

                # 如果 smb.conf 不存在 → 初始化
                if [ ! -f /etc/samba/smb.conf ]; then
                    cat > /etc/samba/smb.conf <<'EOF'
[global]
workgroup = WORKGROUP
security = user
map to guest = Bad User
EOF
                fi

                # 生成共享名（取目录名）
                share_name=$(basename "$custom_path")

                # 追加配置
                cat >> /etc/samba/smb.conf <<EOF

[$share_name]
path = $custom_path
browseable = yes
read only = no
guest ok = yes
create mask = 0777
directory mask = 0777
EOF

                chmod -R 777 "$custom_path"
                systemctl restart smbd

                log "已共享目录: $custom_path (名称: $share_name)"
                ;;

            4)
                systemctl status smbd
                log "SMB 服务状态查询"
                ;;

            5)
                systemctl restart smbd
                log "SMB 服务已重启"
                ;;

            6)
                rm -f /etc/samba/smb.conf
                systemctl disable smbd
                systemctl stop smbd
                log "SMB 配置已删除并关闭启动"
                ;;

            7)
                log "已取消"
                break
                ;;
        esac
        pause
    done
}

# ================= Docker (黄色) =================
docker_menu() {
    while true; do
        print_header "${YELLOW}===== Docker 菜单 =====${NC}"
        echo -e "${YELLOW}1 安装 Docker${NC}"
        echo -e "${YELLOW}2 重启 Docker${NC}"
        echo -e "${RED}3 返回${NC}"
        read -p "选择: " c

        case $c in
            1)
                curl -fsSL https://get.docker.com -o get-docker.sh
                sh get-docker.sh
                log "Docker 安装完成"
                ;;
            2)
                systemctl restart docker
                log "Docker 已重启"
                ;;
            3) break ;;
        esac
        pause
    done
}

# ================= SSH (蓝色) =================
ssh_menu() {
    while true; do
        print_header "${BLUE}===== SSH 菜单 =====${NC}"
        echo -e "${BLUE}1 安装并启用 SSH${NC}"
        echo -e "${BLUE}2 强制写入配置${NC}"
        echo -e "${BLUE}3 查询状态${NC}"
        echo -e "${BLUE}4 重启 SSH${NC}"
        echo -e "${RED}5 返回${NC}"
        read -p "选择: " c

        case $c in
            1)
                apt install -y openssh-server
                systemctl enable ssh
                log "SSH 已安装并开机启动"
                ;;
            2)
                sed -i 's/^#\?PasswordAuthentication.*/PasswordAuthentication yes/' /etc/ssh/sshd_config
                sed -i 's/^#\?PermitRootLogin.*/PermitRootLogin yes/' /etc/ssh/sshd_config
                systemctl restart ssh
                log "SSH 配置已写入"
                ;;
            3)
                systemctl status ssh
                log "SSH 状态查询"
                ;;
            4)
                systemctl restart ssh
                log "SSH 已重启"
                ;;
            5) break ;;
        esac
        pause
    done
}

# ================= GO (紫色) =================
go_menu() {
    while true; do
        print_header "${MAGENTA}===== GO 菜单 =====${NC}"
        echo -e "${MAGENTA}1 安装 GO${NC}"
        echo -e "${RED}2 返回${NC}"
        read -p "选择: " c

        case $c in
            1)
                apt update
                apt install -y golang
                log "GO 已安装"
                ;;
            2) break ;;
        esac
        pause
    done
}

# ================= 服务项 (青色) =================
service_menu() {
    while true; do
        print_header "${CYAN}===== 服务菜单 =====${NC}"
        echo -e "${CYAN}1 创建xxx.service${NC}"
        echo -e "${CYAN}2 启动xxx服务${NC}"
        echo -e "${CYAN}3 查询状态${NC}"
        echo -e "${CYAN}4 创建胖墩墩超级备份系统${NC}"
        echo -e "${RED}5 返回${NC}"
        read -p "选择: " c

        case $c in
            1)
                cat << 'EOF' > /etc/systemd/system/xxx.service
[Unit]
Description=Docker Cluster Management System
After=network.target

[Service]
WorkingDirectory=/X
ExecStart=/X/xxx
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
EOF
                systemctl daemon-reload
                systemctl enable xxx
                log "xxx.service 已写入，设置开机启动"
                ;;
            2)
                systemctl restart xxx
                log "xxx 已重启"
                ;;
            3)
                systemctl status xxx
                log "查询 xxx 状态"
                ;;
            4)
                mkdir -p /X

                # 自动检测并安装 Go
                if ! command -v go >/dev/null 2>&1; then
                    log "未检测到 Go 环境，正在自动安装..."
                    apt update
                    apt install -y golang
                fi

                cat > /X/xxx.go <<'EOF'
package main

import (
	"fmt"
	"github.com/gin-gonic/gin"
	"app/backup"
)

func main() {
	r := gin.Default()
	backup.RegisterBackupHandler(r, "/back_up", "/X")

	fmt.Println("http://localhost/back_up")

	r.Run(":80")
}
EOF
                log "xxx.go创建完成"

                # 必须在编译前先创建 backup 目录并下载 backup.go
                mkdir -p /X/backup
                log "/X/backup创建完成"
                chmod -R 777 /X/backup
                log "/X/backup给予777权限"
                wget -q -O /X/backup/backup.go "https://raw.githubusercontent.com/ZackOd/sh/refs/heads/main/backup.go"
                log "/X/backup/backup.go下载完成"

                # 进入 /X 目录执行编译
                cd /X || exit
                log "进入X目录，即将开始GO初始化，请耐心等待"

                go mod init app
                go get github.com/gin-gonic/gin
                go mod tidy
                log "系统初始化完成,即将开始编译，请耐心等待"
                
                # 开始编译
                go build -o xxx xxx.go
                chmod +x xxx
                log "系统编译完成，准备写入服务项"
                
                # 返回原始目录
                cd - > /dev/null

                # 【终极修复】强制重建服务文件，强刷缓存，暴力启动！
                cat << 'EOF' > /etc/systemd/system/xxx.service
[Unit]
Description=Docker Cluster Management System
After=network.target

[Service]
WorkingDirectory=/X
ExecStart=/X/xxx
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
EOF
                systemctl daemon-reload
                systemctl enable xxx
                systemctl restart xxx
                log "服务进程写入并刷新完成"

                log "超级备份系统已启动: http://$(hostname -I | awk '{print $1}')/back_up"
                ;;
            5) break ;;
        esac
        pause
    done
}

# 启动
# (主菜单开头会自动调用 print_header 并附带标题)
main_menu
